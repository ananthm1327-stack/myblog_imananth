# Copy this file to `.env.local` and fill in the values.
# Leave the file missing (or the vars empty) to run the app in local-only mode.

# Your Supabase project URL — Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Anon public API key — Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# A long random string. This is your owner secret — any client that has this
# can write posts and moderate comments. Keep it out of git.
# Generate with: openssl rand -hex 32   (or paste any 40+ char random string)
VITE_OWNER_TOKEN=replace-with-a-40-char-random-string
